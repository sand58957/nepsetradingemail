# Local development defaults — copy to backend/.env and fill in secrets.
# Ports must match the host mappings in docker-compose.local.yml:
#   Postgres 5435, Redis 6381, Listmonk 9000
PORT=8080
DATABASE_URL=postgres://listmonk:listmonk@localhost:5435/listmonk?sslmode=disable
REDIS_URL=redis://localhost:6381/0
LISTMONK_API_URL=http://localhost:9000/api
LISTMONK_ADMIN_USER=admin
LISTMONK_ADMIN_PASSWORD=admin12345
JWT_SECRET=CHANGE_ME_random_jwt_secret_at_least_32_chars
NEXTAUTH_SECRET=CHANGE_ME_random_nextauth_secret_at_least_32_chars
FRONTEND_URL=http://localhost:3000
SENDGRID_API_KEY=
TELEGRAM_BOT_TOKEN=
BUNNY_CDN_STORAGE_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
